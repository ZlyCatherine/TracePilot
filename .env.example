# TracePilot 环境配置示例文件
# 复制此文件为 .env 并根据实际情况修改
# 请将本文件复制为 .env 后填写真实配置

# ==================== 模型配置 ====================

# 默认模型提供商 (可选：openai, anthropic, aliyun, tencent, z.ai, ollama, other)
DEFAULT_PROVIDER=aliyun

# 默认模型名称
DEFAULT_MODEL=glm-5

# ==================== OpenAI 兼容配置 ====================
# 适用于：OpenAI、阿里云、腾讯云、Z.AI 等兼容接口

# API Key (必填，除非使用 Ollama)
OPENAI_API_KEY=sk-your-api-key-here

# Base URL (可选，使用官方接口可留空或注释)
# OpenAI 官方：https://api.openai.com/v1
# 阿里云：https://dashscope.aliyuncs.com/compatible-mode/v1
# 阿里云 coding: https://coding.dashscope.aliyuncs.com/v1
OPENAI_API_BASE=https://coding.dashscope.aliyuncs.com/v1

# ==================== Anthropic 配置 ====================
# 仅在 DEFAULT_PROVIDER=anthropic 时使用

# API Key
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Base URL (可选，使用代理时配置)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ==================== Ollama 配置 ====================
# 仅在 DEFAULT_PROVIDER=ollama 时使用

# Ollama 本地服务地址 (默认：http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# ==================== MCP 配置 ====================
# 默认关闭。开启后，TracePilot 会在启动时连接一个 stdio MCP server，并把 tools/list 返回的工具加入工具池。

TRACEPILOT_MCP_ENABLED=false

# MCP server 名称会用于工具命名，例如 mcp__web_search__search
TRACEPILOT_MCP_SERVER_NAME=web_search

# MCP server 启动命令与参数。示例：
# TRACEPILOT_MCP_SERVER_COMMAND=python
# TRACEPILOT_MCP_SERVER_ARGS=-m your_search_mcp_server
TRACEPILOT_MCP_SERVER_COMMAND=
TRACEPILOT_MCP_SERVER_ARGS=

# 需要传给 MCP server 的环境变量名，多个用逗号分隔。
# TRACEPILOT_MCP_SERVER_ENV_KEYS=TAVILY_API_KEY,BRAVE_API_KEY
TRACEPILOT_MCP_SERVER_ENV_KEYS=

# MCP 工具调用超时时间。
TRACEPILOT_MCP_TIMEOUT_SECONDS=30
